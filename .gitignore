# =============================================================================
#  Obsidian Vault .gitignore
#  - 머신별 설정 / 캐시 / 휴지통은 동기화 제외
#  - 노트 (.md), 첨부, 핵심 .obsidian 설정만 동기화
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
#  Obsidian 머신별 / 휘발성 파일
# ─────────────────────────────────────────────────────────────────────────────
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/data.json.bak
.obsidian/plugins/*/main.js.map

# Obsidian Git 플러그인 로컬 백업 / 캐시 (혹시 사용 시)
.obsidian/plugins/obsidian-git/

# Obsidian 휴지통 (로컬에서만)
.trash/
.obsidian/.trash/

# ─────────────────────────────────────────────────────────────────────────────
#  OS / IDE 캐시
# ─────────────────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride
._*

# ─────────────────────────────────────────────────────────────────────────────
#  Office / Word 임시파일 (~$xxx.docx, .tmp)
# ─────────────────────────────────────────────────────────────────────────────
~$*
*.tmp
*.swp
*~

# ─────────────────────────────────────────────────────────────────────────────
#  민감정보 / 비밀 (옵션 — 본인 환경에 맞춰 조정)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
secrets/
**/credentials.json
**/private/
